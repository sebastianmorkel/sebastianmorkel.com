---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";
import Tag from "../components/Tag.astro";

// One source of markup, rendered under three configs:
// terminal, editorial, terminal-with-accent-override
const showcases = [
  { theme: "terminal",  accent: undefined,  label: 'data-theme="terminal"' },
  { theme: "editorial", accent: undefined,  label: 'data-theme="editorial"' },
  { theme: "terminal",  accent: "#22d3ee",  label: 'terminal + accent override (--color-accent: #22d3ee)' },
] as const;
---
<BaseLayout title="Styleguide" noindex={true}>
  <div class="sg">
    <h1 class="sg__title">Component styleguide</h1>
    <p class="sg__note">Dev-only artifact, deleted before go-live.</p>

    {showcases.map((sg) => (
      <div class="sg__block" data-theme={sg.theme} style={sg.accent ? `--color-accent: ${sg.accent}` : undefined}>
        <p class="sg__label">{sg.label}</p>

        <Header />

        <Section title="Typography & links">
          <h1>Heading 1</h1>
          <h2>Heading 2</h2>
          <h3>Heading 3</h3>
          <p>
            Body copy with an <Link href="/">internal link</Link> and an 
            <Link href="https://github.com"> external link</Link>. The quick brown fox
            jumps over the lazy dog.
          </p>

          <div class="sg__row">
            <Button href="#">Primary</Button>
            <Button href="#" variant="ghost">Ghost</Button>
            <Button>Submit button</Button>
          </div>

          <div class="sg__row">
            <Tag>ai</Tag><Tag>softwaredev</Tag><Tag>webdev</Tag><Tag>quant</Tag>
            <Tag variant="status" status="live">live</Tag>
            <Tag variant="status" status="in-development">in development</Tag>
            <Tag variant="status" status="planned">planned</Tag>
          </div>
        </Section>

        <Section title="Project cards">
          <div class="sg__grid">
            <ProjectCard
              title="AI Budget Coach"
              summary="A conversational budgeting app that turns plain-English goals into a plan."
              disciplines={["ai", "softwaredev", "webdev"]}
              status="live"
              href="#"
              featured={true}
            />
            <ProjectCard
              title="Portfolio Site"
              summary="This site — Astro, token-based theming, Cloudflare Pages."
              disciplines={["webdev"]}
              status="in-development"
              href="#"
            />
            <ProjectCard
              title="Quant Research Notebook"
              summary="A planned write-up of backtesting experiments."
              disciplines={["quant"]}
              status="planned"
            />
          </div>
        </Section>

        <Footer />
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .sg__title { margin: var(--space-6) var(--space-5) var(--space-2); }
  .sg__note { margin: 0 var(--space-5) var(--space-8); color: var(--color-muted); }
  .sg__block {
    background: var(--color-bg);
    color: var(--color-fg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin: var(--space-6) var(--space-5);
    overflow: hidden;
  }
  .sg__label {
    margin: 0;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
  }
  .sg__row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    margin-block: var(--space-4);
  }
  .sg__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4);
  }
</style>