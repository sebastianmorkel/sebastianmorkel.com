---
// Placeholder home — Phase 0 skeleton. Real terminal/editorial design lands in Phase 2.
const name = "Sebastian Morkel";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sebastian Morkel — coming soon</title>
    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0; min-height: 100dvh; display: grid; place-items: center;
        background: #0a0a0a; color: #e6e6e6;
        font: 16px/1.6 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }
      main { text-align: center; padding: 2rem; }
      .prompt { color: #4ade80; margin: 0; }
      h1 { font-size: clamp(1.5rem, 5vw, 2.5rem); margin: .25rem 0; font-weight: 600; }
      p.tag { color: #9ca3af; margin: 0; }
    </style>
  </head>
  <body>
    <main>
      <p class="prompt">$ whoami</p>
      <h1>{name}</h1>
      <p class="tag">portfolio coming soon</p>
    </main>
  </body>
</html>