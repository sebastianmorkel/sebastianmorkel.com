---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import Link from "../components/Link.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";
import SkillsMarquee from "../components/SkillsMarquee.astro";
import Button from "../components/Button.astro";
import DisciplineLinks from "../components/DisciplineLinks.astro";
import Typewriter from "../components/Typewriter.astro";
import IntroBoot from "../components/IntroBoot.astro";


// Auto-detect an optional headshot at src/assets/headshot.{jpg,jpeg,png,webp}.
// If none is committed yet, we render a styled placeholder.
const headshots = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/headshot.{jpg,jpeg,png,webp}",
  { eager: true }
);
const headshot = Object.values(headshots)[0]?.default;

// My profile URLS.
const profiles = [
  { label: "GitHub",   href: "https://github.com/sebastianmorkel" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/sebastianmorkel" },
  { label: "Email",    href: "mailto:morkel082@gmail.com" },
];

const projects = (await getCollection("projects"))
  .filter((e) => e.data.status === "live")
  .sort((a, b) =>
    Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
    +new Date(b.data.date) - +new Date(a.data.date)
  );
---
<BaseLayout 
  title="Sebastian Morkel - Software · Web · AI/ML"
  description="Sebastian Morkel is a software, web, and AI/ML developer from Cape Town. Explore projects, a filterable skills list, and downloadable per-discipline CVs."
>
  <IntroBoot />
  <Header />

  <Section>
    <div class="hero">
      <div class="hero__media">
        {headshot ? (
          <img
            class="hero__img"
            src={headshot.src}
            width={headshot.width}
            height={headshot.height}
            alt="Sebastian Morkel"
          />
        ) : (
          <div class="hero__placeholder" aria-hidden="true">SM</div>
        )}
      </div>

      <div class="hero__body">
        <p class="hero__prompt">$ whoami</p>
        <h1 class="hero__name">Sebastian Morkel</h1>
        <p class="hero__tagline">
          <span class="hero__chev" aria-hidden="true">&gt;</span>
          <Typewriter phrases={["software developer", "web developer", "AI / ML engineer"]} />
        </p>
        <p class="hero__blurb">
          I build practical software across the stack! From full web apps to AI-driven
          tools. This is where my projects, skills, and writing live.
        </p>
        <p class="hero__cta">
          <Button href="/cv/sebastian-morkel-cv.pdf">Download CV ↓</Button>
        </p>
        <nav class="hero__links" aria-label="Profiles">
          {profiles.map((p) => <Link href={p.href}>{p.label}</Link>)}
        </nav>
        <p class="hero__status">
          <span class="hero__dot" aria-hidden="true"></span>
          Currently: BSc Applied Mathematics @ Stellenbosch · <span class="hero__open">open to internships</span>
        </p>
      </div>
    </div>
  </Section>
  <Section title="Explore">
    <DisciplineLinks />
  </Section>  
  <Section title="Projects">
    <div class="home-projects">
      {projects.map((e) => (
        <ProjectCard
          title={e.data.title}
          summary={e.data.summary}
          disciplines={e.data.disciplines}
          status={e.data.status}
          href={`/projects/${e.id}`}
          featured={e.data.featured}
        />
      ))}
    </div>
  </Section>

  <SkillsMarquee />
  <Footer />
</BaseLayout>

<style>
  .hero {
    display: flex;
    gap: var(--space-8);
    align-items: center;
    flex-wrap: wrap;
  }
  .hero__media { flex: 0 0 auto; }
  .hero__img,
  .hero__placeholder {
    width: 160px;
    height: 160px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    object-fit: cover;
    /* springy easing — overshoots a touch for the "boing" */
    transition: transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 260ms ease;
  }
  /* hover the whole media slot so it works for image OR placeholder */
  .hero__media:hover .hero__img,
  .hero__media:hover .hero__placeholder {
    transform: translateY(-8px) rotate(-4deg);
    box-shadow: var(--shadow-glow);
  }
  /* respect users who ask for less motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__img,
    .hero__placeholder { transition: none; }
    .hero__media:hover .hero__img,
    .hero__media:hover .hero__placeholder { transform: none; }
  }
  .hero__placeholder {
    display: grid;
    place-items: center;
    background: var(--color-surface);
    color: var(--color-muted);
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    text-shadow: var(--shadow-glow);
  }
  .hero__body { flex: 1 1 18rem; }
  .hero__prompt { margin: 0 0 var(--space-2); color: var(--color-accent); font-size: var(--text-sm); }
  .hero__name { margin: 0 0 var(--space-2); }
  .hero__tagline { margin: 0 0 var(--space-4); color: var(--color-muted); }
  .hero__blurb { max-width: 46ch; }
  .hero__cta { margin-top: var(--space-5); }  
  .hero__links { display: flex; gap: var(--space-5); margin-top: var(--space-5); }
  .home-projects {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
    gap: var(--space-4);
  }
  .hero__chev { color: var(--color-accent); margin-right: 0.25rem; }
  .hero__status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }
  .hero__open { color: #34d399; }            /* "available" green */
  .hero__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #34d399;
    animation: status-pulse 2s ease-out infinite;
  }
  @keyframes status-pulse {
    0%   { box-shadow: 0 0 0 0 color-mix(in srgb, #34d399 55%, transparent); }
    70%  { box-shadow: 0 0 0 7px color-mix(in srgb, #34d399 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, #34d399 0%, transparent); }
  }
  @media (prefers-reduced-motion: reduce) { .hero__dot { animation: none; } }
</style>