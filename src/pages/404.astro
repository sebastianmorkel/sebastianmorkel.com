---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---
<BaseLayout title="404 — Not found" description="That page doesn't exist.">
  <Header />
  <Section>
    <p class="nf__prompt">$ 404</p>
    <h1 class="nf__title">page not found</h1>
    <p class="nf__msg">That page doesn't exist (or it moved). Let's get you back on track.</p>
    <p style="margin-top: 1.5rem;"><Button href="/">← back home</Button></p>
  </Section>
  <Footer />
</BaseLayout>

<style>
  .nf__prompt { margin: 0 0 var(--space-2); color: var(--color-accent); font-size: var(--text-sm); }
  .nf__title { margin: 0 0 var(--space-3); }
  .nf__msg { max-width: 50ch; color: var(--color-muted); }
</style>