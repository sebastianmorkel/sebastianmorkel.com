---
interface ProfileLink { label: string; href: string; }
interface Props { links?: ProfileLink[]; }
const {
  links = [
    { label: "GitHub", href: "https://github.com/sebastianmorkel" },
    { label: "LinkedIn", href: "https://linkedin.com/in/sebastianmorkel" },
    { label: "Email", href: "mailto:morkel082@gmail.com" },
  ],
} = Astro.props;
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer__inner">
    <nav class="footer__links" aria-label="Profiles">
      {links.map((l) => <a class="footer__link" href={l.href}>{l.label}</a>)}
    </nav>
    <p class="footer__meta">© {year} Sebastian Morkel</p>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--color-border); margin-top: var(--space-12); }
  .footer__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-6) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .footer__links { display: flex; gap: var(--space-5); }
  .footer__link { color: var(--color-muted); font-size: var(--text-sm); }
  .footer__link:hover { color: var(--color-accent); }
  .footer__meta { color: var(--color-muted); font-size: var(--text-sm); margin: 0; }
</style>