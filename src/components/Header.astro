---
interface NavItem { label: string; href: string; }
interface Props {
  brand?: string;
  items?: NavItem[];
}
const {
  brand = "sebastianmorkel",
  items = [
    { label: "software", href: "/softwaredev" },
    { label: "web", href: "/webdev" },
    { label: "ai", href: "/ai" },
    { label: "skills", href: "/skills" },
  ],
} = Astro.props;
const path = Astro.url.pathname;
---
<header class="header">
  <div class="header__inner">
    <a class="header__brand" href="/"><span class="header__prompt">$</span> {brand}</a>
    <nav class="header__nav" aria-label="Primary">
      {items.map((item) => (
        <a
          class="header__link"
          href={item.href}
          aria-current={path === item.href ? "page" : undefined}
        >{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .header__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .header__brand {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    color: var(--color-fg);
    text-shadow: var(--shadow-glow);
  }
  .header__brand:hover { text-decoration: none; }
  .header__prompt { color: var(--color-accent); }
  .header__nav { display: flex; gap: var(--space-5); flex-wrap: wrap; }
  .header__link { color: var(--color-muted); font-size: var(--text-sm); }
  .header__link:hover { color: var(--color-fg); text-decoration: none; }
  .header__link[aria-current="page"] { color: var(--color-accent); }
  @media (max-width: 480px) {
    .header__inner { flex-direction: column; align-items: flex-start; }
  }
</style>