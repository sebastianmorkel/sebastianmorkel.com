---
interface Props {
  href?: string;
  variant?: "primary" | "ghost";
  type?: "button" | "submit";
}
const { href, variant = "primary", type = "button" } = Astro.props;
const Element = href ? "a" : "button";
---
<Element class:list={["btn", `btn--${variant}`]} href={href} type={href ? undefined : type}>
  <slot />
</Element>

<style>
  .btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: 1;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-accent);
    cursor: pointer;
    text-decoration: none;
    transition: background var(--transition), color var(--transition), box-shadow var(--transition);
  }
  .btn:hover { text-decoration: none; box-shadow: var(--shadow-glow); }
  .btn--primary { background: var(--color-accent); color: var(--color-bg); }
  .btn--ghost { background: transparent; color: var(--color-accent); }
  .btn--ghost:hover { background: var(--color-surface); }
</style>
