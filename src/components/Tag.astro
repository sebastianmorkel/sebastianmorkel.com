---
interface Props {
  variant?: "tag" | "status";
  status?: "live" | "in-development" | "planned";
}
const { variant = "tag", status } = Astro.props;
---
<span class:list={["tag", `tag--${variant}`, status && `tag--${status}`]}>
  <slot />
</span>

<style>
  .tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
  .tag--status { border-color: var(--color-accent); color: var(--color-accent); }
  .tag--in-development { color: var(--color-fg); border-color: var(--color-fg); opacity: 0.85; }
  .tag--planned { color: var(--color-muted); border-color: var(--color-border); }
</style>