---
import Tag from "./Tag.astro";

interface Props {
  title: string;
  summary: string;
  disciplines: string[];
  status?: "live" | "in-development" | "planned";
  href?: string;
  featured?: boolean;
}
const { title, summary, disciplines, status = "live", href, featured } = Astro.props;
const statusLabel = status.replace("-", " ");
---
<article class:list={["card", featured && "card--featured"]}>
  <div class="card__head">
    <h3 class="card__title">
      {href ? <a href={href} class="card__link">{title}</a> : title}
    </h3>
    <Tag variant="status" status={status}>{statusLabel}</Tag>
  </div>
  <p class="card__summary">{summary}</p>
  <div class="card__tags">
    {disciplines.map((d) => <Tag>{d}</Tag>)}
  </div>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .card:hover { border-color: var(--color-accent); box-shadow: var(--shadow-glow); }
  .card--featured { border-color: var(--color-accent); }
  .card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;          /* badge drops to its own line instead of clipping */
  }
  .card__title {
    margin: 0;
    font-size: var(--text-lg);
    min-width: 0;
  }
  /* keep the status badge intact and inside the border */
  .card__head :global(.tag) {
    flex-shrink: 0;
    white-space: nowrap;
  }
  .card__link { color: var(--color-fg); }
  .card__link:hover { color: var(--color-accent); text-decoration: none; }
  .card__summary { margin: 0; color: var(--color-muted); font-size: var(--text-sm); }
  .card__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
</style>